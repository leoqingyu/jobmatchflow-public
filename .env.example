# =============================================================
# JobMatchFlow environment configuration
#
# Copy this file to `.env` in the project root and fill in the values you
# need. Never commit the real `.env` file — it is already gitignored.
#
# Every variable here maps 1:1 to a field on `Settings` in core/config.py
# (same name, upper snake case). Anything left blank falls back to the
# default shown in core/config.py.
# =============================================================

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobmatchflow
# Log every SQL statement (very verbose) — useful only when debugging the DB layer.
DATABASE_ECHO=false

# ---------- App environment ----------
ENVIRONMENT=development
DEBUG=true
JOBS_LIST_DIAGNOSTICS=true
JOBS_LIST_DEBUG_SHOW_ALL=true
JOBS_LIST_MODEL_COMPARISON=false
SCORE_THRESHOLD_REVIEW=60
SCORE_THRESHOLD_GENERATE=80

# ---------- Gemini (primary pipeline model: dedup, scoring, JD extraction) ----------
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-3.1-flash-lite
# Optional keys if you want to split quota/billing from the main key; falls back
# to GEMINI_API_KEY when left blank.
GEMINI_PRO_API_KEY=
GEMINI_LITE_API_KEY=
# Explicit context caching for scoring (master CV + prompt cached, only the JD
# is sent per job). Falls back to uncached calls automatically on failure.
GEMINI_SCORING_EXPLICIT_CACHE=true
GEMINI_SCORING_CACHE_TTL_SECONDS=600

# ---------- Scoring model routing (see ai/llm_factory.py) ----------
# Each stage can point at a different provider/model, matched by name prefix:
#   cheap = preference-bonus pass (optional, cheapest model is fine)
#   mid   = JD structured extraction + direction-vector expansion (quality-sensitive)
#   match = per-requirement matching against the candidate
SCORING_MODEL_CHEAP=gemini-3.1-flash-lite
SCORING_MODEL_MID=gemini-3.1-flash-lite
SCORING_MODEL_MATCH=gemini-3.1-flash-lite
RESUME_REWRITE_MODEL=gemini-3.1-flash-lite

# ---------- DeepSeek (OpenAI-compatible endpoint, optional) ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/beta
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# ---------- Qwen / DashScope (OpenAI-compatible endpoint, optional) ----------
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen3.5-flash

# ---------- Claude (used for resume/cover-letter generation when a user picks
# "claude" as their UserProfile.generation_model; leave blank to disable that
# option — see ai/llm_factory.py::get_generation_llm_client) ----------
CLAUDE_API_KEY=
CLAUDE_MODEL_NAME=claude-sonnet-5

# ---------- Local embedding models (HuggingFace hub ids, resolved via the
# local sentence-transformers cache at ~/.cache/huggingface) ----------
JOB_DEDUP_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
SCORING_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ---------- File storage ----------
STORAGE_PROVIDER=local
LOCAL_STORAGE_BASE_PATH=data

# ---------- PDF generation ----------
# chromium (Playwright) | weasyprint | weasyprint_first
PDF_ENGINE=chromium
PDF_PAGE_FORMAT=a4
PDF_PRINT_BACKGROUND=false
# LibreOffice headless binary, used to validate DOCX page count before export.
# Skipped silently if not found.
LIBREOFFICE_BINARY_PATH=soffice

# ---------- Email notifications (Resend) ----------
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=

# ---------- Scraping ----------
SCRAPE_LIMIT_PER_SEARCH=500
SCRAPE_HOURS_OLD=24
SCRAPE_REQUEST_DELAY_MIN_SEC=5.0
SCRAPE_REQUEST_DELAY_MAX_SEC=15.0
# Optional bearer token required by api/debug_app.py when set.
DEBUG_API_TOKEN=

# ---------- Matching worker (scripts/run_matching_worker.py) ----------
MATCHING_WORKER_DELAY_MIN_SEC=3.0
MATCHING_WORKER_DELAY_MAX_SEC=10.0
MATCHING_WORKER_IDLE_POLL_SEC=300.0

# ---------- Auth ----------
# Signing key for the httpOnly JWT session cookie. Generate a real random value,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"` — required in
# production, the app refuses to start with this empty when ENVIRONMENT=production.
SECRET_KEY=
JWT_EXPIRES_DAYS=7

# Used ONCE at startup to create the first admin account if none exists yet.
# Not a login path itself — the admin logs in normally afterwards with this
# email/password (stored as a real bcrypt hash, like any other user).
ADMIN_BOOTSTRAP_EMAIL=admin@jobmatchflow.local
ADMIN_BOOTSTRAP_PASSWORD=

# ---------- API ----------
# Comma-separated allowed origins; empty means allow all (dev only).
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_GENERATE_MAX_CONCURRENT=12
